<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="8dp">

        <!-- Donation Information Text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Support our cause by donating through Zapper or with the payment portal below:"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- QR Code Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/qrCodeImage"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:padding="16dp"
                android:scaleType="centerInside"
                android:contentDescription="Donation QR Code"
                android:src="@drawable/qrcode" />
        </androidx.cardview.widget.CardView>

        <!-- Introduction Text -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Your Donation Makes a Difference"
            android:textSize="24sp"
            android:textColor="@android:color/black"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="By donating to USE-IT, you’re helping to divert waste from landfills, create employment opportunities, and build a sustainable green economy. Your contribution supports training programs, upcycling initiatives, and the development of small businesses in waste beneficiation, ensuring a cleaner environment and a brighter future for our communities."
            android:textSize="16sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="16dp"
            android:lineSpacingExtra="4dp" />

        <!-- Donation Amount Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Donation Amount"
            android:textSize="18sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/amountRadioGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <RadioButton
                android:id="@+id/amount50"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R50" />

            <RadioButton
                android:id="@+id/amount100"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R100"
                android:layout_marginStart="16dp" />

            <RadioButton
                android:id="@+id/amount200"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R200"
                android:layout_marginStart="16dp" />

            <RadioButton
                android:id="@+id/customAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Custom Amount"
                android:layout_marginStart="16dp" />
        </RadioGroup>

        <!-- Custom Amount Input -->
        <EditText
            android:id="@+id/customAmountEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter custom amount"
            android:inputType="numberDecimal"
            android:visibility="gone"
            android:background="@drawable/edit_text_background"
            android:padding="12dp"
            android:layout_marginTop="8dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@android:color/darker_gray"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

        <!-- Card Details Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter Card Details"
            android:textSize="18sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/cardNumberEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Card Number"
            android:inputType="number"
            android:background="@drawable/edit_text_background"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="12dp">

            <EditText
                android:id="@+id/expiryDateEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Expiry Date (MM/YY)"
                android:inputType="text"
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:textSize="14dp"
                android:layout_marginEnd="8dp" />

            <EditText
                android:id="@+id/cvvEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="CVV"
                android:inputType="numberPassword"
                android:background="@drawable/edit_text_background"
                android:padding="12dp" />
        </LinearLayout>

        <!-- Donate Button -->
        <Button
            android:id="@+id/donateButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Donate Now"
            android:textSize="16sp"
            android:textColor="@android:color/white"
            android:backgroundTint="?attr/colorPrimary"
            android:layout_marginTop="16dp"
            android:padding="12dp"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>

</ScrollView>
